#!/bin/bash
set -o errexit
set -o nounset
set -o pipefail

# Load shared environment setup
source "$(dirname "$0")/env.sh"

# Backup the database before proceeding.
if [[ "${ENVIRONMENT}" == "production" ]] && [[ -f "${DATABASE_FILE}" ]]; then
  DATABASE_BACKUP_FILE="${DATABASE_FILE}-$(date +%s)"
  echo "VACUUM INTO '${DATABASE_BACKUP_FILE}'" | sqlite3 "${DATABASE_FILE}"
fi

# Install dependencies
echo "Installing dependencies..."
bun install

# Generate Prisma client if prisma is installed (database-auth skill)
if [ -f "prisma/schema.prisma" ]; then
  echo "Generating Prisma client..."
  bunx prisma generate

  # Skip db push when using Turso (remote database via driver adapter)
  # Schema is managed separately via scripts/push-turso-schema.ts
  if [ -z "${TURSO_DATABASE_URL:-}" ]; then
    echo "Pushing schema to local database..."
    bunx prisma db push --accept-data-loss
  else
    echo "Using Turso remote database - skipping local db push"
  fi
fi

# Start server based on environment
# Use bun directly (not "bun run") so signals propagate correctly
if [[ "${ENVIRONMENT}" == "production" ]]; then
  echo "Starting server in production mode..."
  exec bun src/index.ts
else
  echo "Starting server in dev mode with hot reload..."
  exec bun --hot src/index.ts
fi
