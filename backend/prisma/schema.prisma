generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Waterway types: river, lake, strait, bay, etc.
model WaterwayType {
  id        String     @id @default(cuid())
  name      String     @unique // "River", "Lake", "Bay", "Strait", etc.
  waterways Waterway[]
}

// Main waterway entity (rivers, lakes, etc.)
model Waterway {
  id              String        @id @default(cuid())
  name            String        // English name
  indigenousName  String?       // Indigenous/Aboriginal name
  indigenousLanguage String?    // Language of indigenous name (e.g., "Cree", "Ojibwe")
  description     String        // General description

  // Geographic data
  latitude        Float         // Center point latitude
  longitude       Float         // Center point longitude
  regionName      String        // Province or territory

  // Boundary coordinates stored as JSON string [[lat, lng], [lat, lng], ...]
  // For rivers: polyline following the river path
  // For lakes: polygon outline of the lake
  boundaryCoordinates String?   // JSON array of coordinate pairs

  // Type relation
  typeId          String
  type            WaterwayType  @relation(fields: [typeId], references: [id])

  // Historical significance
  historicalSignificance String? // Historical importance summary

  // Relations
  explorers       ExplorerWaterway[]
  furTradeInfo    FurTradeInfo?
  locations       Location[]
  contributions   UserContribution[]
  discoveries     ArchaeologicalDiscovery[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// Notable locations on waterways (forts, portages, trading posts, etc.)
model Location {
  id              String    @id @default(cuid())
  name            String
  indigenousName  String?
  indigenousLanguage String?
  description     String

  // Geographic
  latitude        Float
  longitude       Float

  // Type: "Fort", "Trading Post", "Portage", "Settlement", "Cultural Site"
  locationType    String

  // Historical info
  yearEstablished Int?
  historicalNotes String?

  // Relation to waterway
  waterwayId      String
  waterway        Waterway  @relation(fields: [waterwayId], references: [id], onDelete: Cascade)

  // Cartographer who mapped this
  cartographerId  String?
  cartographer    Cartographer? @relation(fields: [cartographerId], references: [id])

  // User contributions
  contributions   UserContribution[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Historical explorers
model Explorer {
  id              String    @id @default(cuid())
  name            String
  birthYear       Int?
  deathYear       Int?
  nationality     String?
  biography       String    // Short biography
  notableAchievements String? // Key achievements
  imageUrl        String?   // Portrait image

  // Relations
  waterways       ExplorerWaterway[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Many-to-many: Explorer <-> Waterway with exploration details
model ExplorerWaterway {
  id              String    @id @default(cuid())
  explorerId      String
  explorer        Explorer  @relation(fields: [explorerId], references: [id], onDelete: Cascade)
  waterwayId      String
  waterway        Waterway  @relation(fields: [waterwayId], references: [id], onDelete: Cascade)

  yearExplored    Int?      // Year of exploration
  expeditionNotes String?   // Notes about this specific exploration

  @@unique([explorerId, waterwayId])
}

// Fur trade information for waterways
model FurTradeInfo {
  id              String    @id @default(cuid())
  waterwayId      String    @unique
  waterway        Waterway  @relation(fields: [waterwayId], references: [id], onDelete: Cascade)

  tradingCompany  String?   // "Hudson's Bay Company", "North West Company", etc.
  peakTradePeriod String?   // e.g., "1780-1821"
  primaryFurs     String?   // "Beaver, Marten, Otter"
  tradeRouteNotes String?   // Description of trade route significance

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Historical cartographers
model Cartographer {
  id              String    @id @default(cuid())
  name            String
  birthYear       Int?
  deathYear       Int?
  nationality     String?
  biography       String?
  notableMaps     String?   // Description of notable maps created

  // Locations they mapped
  locations       Location[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Indigenous nations and their territories (for cultural significance)
model IndigenousNation {
  id              String    @id @default(cuid())
  name            String    // Nation name
  alternateNames  String?   // Other names/spellings
  languageFamily  String?   // e.g., "Algonquian", "Iroquoian", "Athapaskan"
  traditionalTerritory String? // Description of traditional lands
  culturalNotes   String?   // Cultural significance of waterways

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ==================== USER CONTRIBUTION SYSTEM ====================

// User contributions - photos, descriptions, historical info
model UserContribution {
  id              String    @id @default(cuid())

  // What type of contribution
  contributionType String   // "photo", "description", "historical_fact", "story"

  // Content
  title           String
  content         String    // Description or text content
  imageUrl        String?   // URL to uploaded image (if photo)

  // Contributor info (anonymous allowed)
  contributorName String?   // Optional name
  contributorEmail String?  // For follow-up (not displayed)

  // Related to waterway or location
  waterwayId      String?
  waterway        Waterway? @relation(fields: [waterwayId], references: [id], onDelete: Cascade)
  locationId      String?
  location        Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)

  // Moderation
  status          String    @default("pending") // "pending", "approved", "rejected"
  adminNotes      String?   // Notes from admin about rejection reason, etc.
  reviewedAt      DateTime?
  reviewedBy      String?   // Admin who reviewed

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Admin users for content moderation
model AdminUser {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String
  passwordHash    String    // Hashed password
  role            String    @default("moderator") // "moderator", "admin", "superadmin"

  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Archaeological discoveries related to historical expeditions
model ArchaeologicalDiscovery {
  id              String    @id @default(cuid())
  name            String    // Name of discovery (e.g., "HMS Erebus Wreck")
  discoveryYear   Int       // Year discovered
  description     String    // Detailed description of what was found
  significance    String    // Historical significance

  // Related expedition/explorer info
  relatedExpedition String? // Name of the expedition it relates to
  relatedExplorerName String? // Explorer name if applicable
  expeditionYear  Int?      // Year of the original expedition

  // Location
  latitude        Float?
  longitude       Float?
  locationDescription String? // Text description of location

  // Related waterway
  waterwayId      String?
  waterway        Waterway? @relation(fields: [waterwayId], references: [id], onDelete: SetNull)

  // Sources and further reading
  sources         String?   // Archaeological sources/references

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ==================== QUIZ SYSTEM FOR RCGS EDUCATION ====================

// Quiz - a collection of questions for K-12 education
model Quiz {
  id              String    @id @default(cuid())
  title           String    // Quiz title (e.g., "Explorers of the West Coast")
  description     String?   // Description of the quiz

  // Target audience
  gradeLevel      String?   // e.g., "K-3", "4-6", "7-9", "10-12", "All"
  difficulty      String    @default("medium") // "easy", "medium", "hard"

  // Category/topic
  category        String    // e.g., "Explorers", "Fur Trade", "Indigenous Heritage", "Geography", "Maritime History"

  // Status
  isPublished     Boolean   @default(false)

  // Admin who created
  createdById     String?

  // Relations
  questions       QuizQuestion[]
  attempts        QuizAttempt[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// QuizQuestion - individual multiple choice question
model QuizQuestion {
  id              String    @id @default(cuid())
  quizId          String
  quiz            Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)

  // Question content
  questionText    String    // The question itself
  questionType    String    @default("multiple_choice") // "multiple_choice", "true_false"

  // Answer options (stored as JSON array)
  // Format: [{"id": "a", "text": "Option A"}, {"id": "b", "text": "Option B"}, ...]
  options         String    // JSON array of options

  // Correct answer
  correctAnswer   String    // The ID of the correct option (e.g., "a", "b", "c", "d")

  // Explanation shown after answering
  explanation     String?   // Why this answer is correct (educational context)

  // Optional reference to source data
  sourceType      String?   // "explorer", "waterway", "location", "discovery", "fur_trade"
  sourceId        String?   // ID of the referenced entity

  // Order in quiz
  orderIndex      Int       @default(0)

  // Points for this question
  points          Int       @default(1)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// QuizAttempt - record of a student taking a quiz
model QuizAttempt {
  id              String    @id @default(cuid())
  quizId          String
  quiz            Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)

  // Student info (anonymous - no account required)
  studentName     String?   // Optional name
  studentGrade    String?   // Grade level
  schoolName      String?   // Optional school name

  // Results
  score           Int       // Number of correct answers
  totalQuestions  Int       // Total questions in quiz
  totalPoints     Int       // Total points earned
  maxPoints       Int       // Maximum possible points
  percentageScore Float     // Percentage score

  // Answers given (stored as JSON)
  // Format: [{"questionId": "xxx", "selectedAnswer": "a", "isCorrect": true}, ...]
  answers         String    // JSON array of answers

  // Timing
  startedAt       DateTime  @default(now())
  completedAt     DateTime?

  createdAt       DateTime  @default(now())
}

// ==================== LESSON PLANS FOR RCGS EDUCATION ====================

// Lesson Plan - comprehensive teaching resources for K-12
model LessonPlan {
  id              String    @id @default(cuid())
  title           String    // e.g., "The Voyageur Era: Life on the Fur Trade Routes"
  description     String    // Overview of the lesson

  // Target audience
  gradeLevel      String    // "K-3", "4-6", "7-9", "10-12"

  // Topic/theme
  topic           String    // "Early Explorers", "Fur Trade", "Indigenous Routes", "Maritime Discovery", "Archaeology", "Cartography"

  // Curriculum connections (stored as JSON array)
  // Format: [{"subject": "Social Studies", "strand": "Heritage and Identity", "expectation": "..."}]
  curriculumConnections String?

  // Learning objectives (JSON array)
  // Format: ["Describe the role of...", "Identify key explorers...", "Analyze the impact of..."]
  objectives      String

  // Duration
  estimatedMinutes Int      @default(60)

  // Materials needed (JSON array)
  materials       String?

  // Lesson content sections
  introduction    String?   // Hook/introduction text
  mainContent     String    // Core lesson content (can include markdown)
  activities      String?   // Suggested activities (JSON array)
  discussionQuestions String? // Discussion questions (JSON array)
  assessment      String?   // Assessment suggestions
  extensions      String?   // Extension activities for advanced learners

  // Related content
  relatedQuizIds  String?   // JSON array of related quiz IDs
  relatedWaterwayIds String? // JSON array of related waterway IDs
  relatedLocationIds String? // JSON array of related location IDs
  relatedExplorerIds String? // JSON array of related explorer IDs

  // Status
  isPublished     Boolean   @default(false)

  // Admin who created
  createdById     String?

  // Relations
  assignments     ClassAssignment[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ==================== INTERACTIVE TIMELINE ====================

// Timeline Event - chronological events for interactive timeline
model TimelineEvent {
  id              String    @id @default(cuid())
  title           String    // Event title
  description     String    // Event description

  // Date info
  year            Int       // Year of event
  month           Int?      // Optional month (1-12)
  day             Int?      // Optional day
  endYear         Int?      // End year for spanning events
  isApproximate   Boolean   @default(false) // "circa" dates

  // Theme/category for filtering
  theme           String    // "exploration", "fur_trade", "indigenous", "maritime", "archaeology", "settlement"

  // Visual
  imageUrl        String?   // Image for the event
  iconType        String?   // Icon type for timeline display

  // Related entities (optional)
  explorerId      String?   // Related explorer if applicable
  waterwayId      String?   // Related waterway if applicable
  locationId      String?   // Related location if applicable

  // Importance level for filtering
  importance      String    @default("normal") // "major", "normal", "minor"

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ==================== VIRTUAL FIELD TRIPS ====================

// Virtual Field Trip - guided tours following explorer routes
model VirtualFieldTrip {
  id              String    @id @default(cuid())
  title           String    // e.g., "Paddle the Voyageur Highway"
  description     String    // Trip overview

  // Target audience
  gradeLevel      String    // "K-3", "4-6", "7-9", "10-12", "All"

  // Duration
  estimatedMinutes Int      @default(30)

  // Theme
  theme           String    // "voyageur", "explorer", "indigenous", "maritime", "fur_trade"

  // Cover image
  coverImageUrl   String?

  // Status
  isPublished     Boolean   @default(false)

  // Stops on the trip
  stops           FieldTripStop[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Field Trip Stop - individual location on a virtual field trip
model FieldTripStop {
  id              String    @id @default(cuid())
  tripId          String
  trip            VirtualFieldTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  // Order in trip
  orderIndex      Int

  // Stop info
  title           String    // Stop title
  description     String    // Narrative description (storytelling)

  // Location (can link to existing location or be custom)
  locationId      String?   // Link to existing Location if applicable
  waterwayId      String?   // Link to existing Waterway if applicable

  // Custom coordinates if not linked to existing location
  latitude        Float
  longitude       Float

  // Media
  imageUrl        String?
  audioUrl        String?   // Narration audio

  // Interactive elements
  funFact         String?   // Fun fact for kids
  thinkQuestion   String?   // Question to ponder

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ==================== PRIMARY SOURCE DOCUMENTS ====================

// Primary Source Document - historical documents with annotations
model PrimarySourceDocument {
  id              String    @id @default(cuid())
  title           String    // e.g., "Samuel Hearne's Journal Entry, July 1771"

  // Document type
  documentType    String    // "journal", "map", "treaty", "letter", "report", "illustration"

  // Source info
  author          String?   // Original author
  originalDate    String?   // Date of original document
  originalYear    Int?      // Year for sorting

  // Content
  originalText    String?   // Original text (if text document)
  transcription   String?   // Modern transcription
  imageUrl        String?   // Image of document (maps, illustrations)

  // Age-appropriate annotations (JSON array)
  // Format: [{"gradeLevel": "K-3", "annotation": "simplified explanation"}, ...]
  annotations     String?

  // Context
  historicalContext String? // Background context

  // Vocabulary (JSON array of difficult words with definitions)
  vocabulary      String?

  // Discussion questions (JSON array)
  discussionQuestions String?

  // Related entities
  explorerId      String?
  waterwayId      String?
  locationId      String?

  // Target audience
  gradeLevel      String?   // Minimum grade level recommended

  isPublished     Boolean   @default(false)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ==================== COMPARISON TOOLS ====================

// Comparison Template - predefined comparisons
model ComparisonTemplate {
  id              String    @id @default(cuid())
  title           String    // e.g., "East Coast vs West Coast Exploration"
  description     String    // What this comparison explores

  // Comparison type
  comparisonType  String    // "explorers", "forts", "perspectives", "time_periods", "trade_companies"

  // Items to compare (JSON)
  // Format depends on type:
  // explorers: [{"id": "xxx", "name": "..."}, {"id": "yyy", "name": "..."}]
  // perspectives: [{"perspective": "Indigenous", "content": "..."}, {"perspective": "European", "content": "..."}]
  items           String

  // Comparison criteria (JSON array)
  // Format: [{"criterion": "Time Period", "description": "When did they explore?"}, ...]
  criteria        String

  // Analysis prompts for students
  analysisPrompts String?   // JSON array of discussion questions

  // Target audience
  gradeLevel      String    // "K-3", "4-6", "7-9", "10-12"

  isPublished     Boolean   @default(false)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ==================== STUDENT JOURNALS ====================

// Student Journal - digital notebook for students
model StudentJournal {
  id              String    @id @default(cuid())

  // Student identifier (anonymous - device-based or simple name)
  studentIdentifier String  // Could be device ID or chosen username
  studentName     String?   // Optional display name
  schoolName      String?   // Optional school
  gradeLevel      String?   // Student's grade

  // Journal entries
  entries         JournalEntry[]

  // Saved locations (bookmarks)
  savedLocations  SavedLocation[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Journal Entry - individual note in student journal
model JournalEntry {
  id              String    @id @default(cuid())
  journalId       String
  journal         StudentJournal @relation(fields: [journalId], references: [id], onDelete: Cascade)

  // Entry content
  title           String?
  content         String    // Student's notes/thoughts

  // What they're writing about (optional links)
  waterwayId      String?
  locationId      String?
  explorerId      String?
  quizId          String?
  lessonPlanId    String?
  fieldTripId     String?

  // Tags (JSON array)
  tags            String?   // e.g., ["fur trade", "explorer"]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Saved Location - bookmarked locations in student journal
model SavedLocation {
  id              String    @id @default(cuid())
  journalId       String
  journal         StudentJournal @relation(fields: [journalId], references: [id], onDelete: Cascade)

  // What they saved
  waterwayId      String?
  locationId      String?
  explorerId      String?

  // Notes about why they saved it
  notes           String?

  createdAt       DateTime  @default(now())
}

// ==================== CLASS MANAGEMENT ====================

// Teacher - teacher account for class management
model Teacher {
  id              String    @id @default(cuid())

  // Account info
  email           String    @unique
  name            String
  passwordHash    String

  // School info
  schoolName      String?
  schoolDistrict  String?
  province        String?

  // Classes they manage
  classes         Class[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Class - a group of students managed by a teacher
model Class {
  id              String    @id @default(cuid())

  // Class info
  name            String    // e.g., "Grade 7 Social Studies - Period 2"
  gradeLevel      String    // "K-3", "4-6", "7-9", "10-12"
  schoolYear      String?   // e.g., "2025-2026"

  // Join code for students
  joinCode        String    @unique // Simple code for students to join

  // Teacher
  teacherId       String
  teacher         Teacher   @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  // Students
  students        ClassStudent[]

  // Assignments
  assignments     ClassAssignment[]

  isActive        Boolean   @default(true)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Class Student - student enrolled in a class
model ClassStudent {
  id              String    @id @default(cuid())
  classId         String
  class           Class     @relation(fields: [classId], references: [id], onDelete: Cascade)

  // Student identifier
  displayName     String    // Student's display name
  studentCode     String?   // Optional student ID

  // Progress tracking
  progress        StudentProgress[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([classId, displayName])
}

// Class Assignment - assigned quizzes or lesson plans
model ClassAssignment {
  id              String    @id @default(cuid())
  classId         String
  class           Class     @relation(fields: [classId], references: [id], onDelete: Cascade)

  // What's assigned
  assignmentType  String    // "quiz", "lesson_plan", "field_trip"
  quizId          String?
  lessonPlanId    String?
  lessonPlan      LessonPlan? @relation(fields: [lessonPlanId], references: [id])
  fieldTripId     String?

  // Assignment details
  title           String    // Assignment title/description
  instructions    String?   // Teacher's instructions

  // Due date
  dueDate         DateTime?

  // Student progress
  progress        StudentProgress[]

  isActive        Boolean   @default(true)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Student Progress - tracks student completion of assignments
model StudentProgress {
  id              String    @id @default(cuid())
  studentId       String
  student         ClassStudent @relation(fields: [studentId], references: [id], onDelete: Cascade)
  assignmentId    String
  assignment      ClassAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  // Status
  status          String    @default("not_started") // "not_started", "in_progress", "completed"

  // Score (for quizzes)
  score           Int?
  maxScore        Int?

  // Timestamps
  startedAt       DateTime?
  completedAt     DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([studentId, assignmentId])
}

// ==================== PRINTABLE RESOURCES ====================

// Printable Resource - worksheets, maps, activities for offline use
model PrintableResource {
  id              String    @id @default(cuid())
  title           String    // e.g., "Blank Map of Canadian Fur Trade Routes"
  description     String    // What this resource is

  // Type
  resourceType    String    // "worksheet", "map", "activity_sheet", "coloring_page", "timeline", "quiz_printable"

  // Target audience
  gradeLevel      String    // "K-3", "4-6", "7-9", "10-12", "All"

  // Topic
  topic           String    // "explorers", "fur_trade", "indigenous", "geography", "maritime"

  // File info
  fileUrl         String?   // URL to PDF or printable file
  previewImageUrl String?   // Preview thumbnail

  // If it's a worksheet, include content (for dynamic generation)
  content         String?   // HTML/Markdown content for dynamic worksheets

  // Instructions for teachers
  teacherNotes    String?

  // Answer key (for worksheets)
  answerKey       String?   // JSON or text answer key

  isPublished     Boolean   @default(false)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ==================== PRONUNCIATION GUIDE ====================

// Pronunciation Guide - audio pronunciations for names
model PronunciationGuide {
  id              String    @id @default(cuid())

  // The word/name
  term            String    // The word to pronounce

  // Type of term
  termType        String    // "indigenous_place", "indigenous_nation", "explorer", "french", "location"

  // Language info
  language        String?   // e.g., "Cree", "Ojibwe", "French", "Inuktitut"

  // Pronunciation
  phonetic        String    // Phonetic spelling (e.g., "miss-sin-AY-bee")
  audioUrl        String?   // URL to audio file

  // Additional info
  meaning         String?   // What the word means
  notes           String?   // Pronunciation notes/tips

  // Related entities
  waterwayId      String?
  locationId      String?
  indigenousNationId String?
  explorerId      String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([term, termType])
}
