generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model WaterwayType {
  id        String     @id @default(cuid())
  name      String     @unique
  waterways Waterway[]
}

model Waterway {
  id                     String                    @id @default(cuid())
  name                   String
  indigenousName         String?
  indigenousLanguage     String?
  description            String
  latitude               Float
  longitude              Float
  regionName             String
  typeId                 String
  historicalSignificance String?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  kmlData                String?
  imageUrl               String?                   // Primary image
  galleryImages          String?                   // JSON array: [{url, caption, credit}]
  videoUrl               String?                   // YouTube or video URL
  discoveries            ArchaeologicalDiscovery[]
  explorers              ExplorerWaterway[]
  notableFigures         NotableFigureWaterway[]
  furTradeInfo           FurTradeInfo?
  locations              Location[]
  contributions          UserContribution[]
  type                   WaterwayType              @relation(fields: [typeId], references: [id])

  @@index([regionName])
  @@index([typeId])
  @@index([name])
}

model Location {
  id                 String             @id @default(cuid())
  name               String
  indigenousName     String?
  indigenousLanguage String?
  description        String
  latitude           Float
  longitude          Float
  locationType       String
  yearEstablished    Int?
  historicalNotes    String?
  imageUrl           String?
  galleryImages      String?            // JSON array: [{url, caption, credit}]
  videoUrl           String?            // YouTube or video URL
  waterwayId         String
  cartographerId     String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  cartographer       Cartographer?      @relation(fields: [cartographerId], references: [id])
  waterway           Waterway           @relation(fields: [waterwayId], references: [id], onDelete: Cascade)
  contributions      UserContribution[]

  @@index([waterwayId])
  @@index([locationType])
  @@index([name])
}

model Explorer {
  id                  String             @id @default(cuid())
  name                String
  birthYear           Int?
  deathYear           Int?
  nationality         String?
  biography           String
  notableAchievements String?
  imageUrl            String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  waterways           ExplorerWaterway[]

  @@index([name])
  @@index([nationality])
}

model ExplorerWaterway {
  id              String   @id @default(cuid())
  explorerId      String
  waterwayId      String
  yearExplored    Int?
  expeditionNotes String?
  waterway        Waterway @relation(fields: [waterwayId], references: [id], onDelete: Cascade)
  explorer        Explorer @relation(fields: [explorerId], references: [id], onDelete: Cascade)

  @@unique([explorerId, waterwayId])
}

model NotableFigureWaterway {
  id              String        @id @default(cuid())
  notableFigureId String
  waterwayId      String
  relationship    String?
  notes           String?
  notableFigure   NotableFigure @relation(fields: [notableFigureId], references: [id], onDelete: Cascade)
  waterway        Waterway      @relation(fields: [waterwayId], references: [id], onDelete: Cascade)

  @@unique([notableFigureId, waterwayId])
  @@index([waterwayId])
  @@index([notableFigureId])
}

model FurTradeInfo {
  id              String   @id @default(cuid())
  waterwayId      String   @unique
  tradingCompany  String?
  peakTradePeriod String?
  primaryFurs     String?
  tradeRouteNotes String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  waterway        Waterway @relation(fields: [waterwayId], references: [id], onDelete: Cascade)
}

model Cartographer {
  id          String     @id @default(cuid())
  name        String
  birthYear   Int?
  deathYear   Int?
  nationality String?
  biography   String?
  notableMaps String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  locations   Location[]
}

model IndigenousNation {
  id                   String   @id @default(cuid())
  name                 String
  alternateNames       String?
  languageFamily       String?
  traditionalTerritory String?
  culturalNotes        String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model UserContribution {
  id               String    @id @default(cuid())
  contributionType String
  title            String
  content          String
  imageUrl         String?
  contributorName  String?
  contributorEmail String?
  waterwayId       String?
  locationId       String?
  status           String    @default("pending")
  adminNotes       String?
  reviewedAt       DateTime?
  reviewedBy       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  location         Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)
  waterway         Waterway? @relation(fields: [waterwayId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([contributionType])
  @@index([createdAt])
}

model AdminUser {
  id                    String    @id @default(cuid())
  email                 String    @unique
  name                  String
  organization          String?
  passwordHash          String
  role                  String    @default("moderator")
  status                String    @default("pending")
  approvedBy            String?
  approvedAt            DateTime?
  rejectionReason       String?
  canCreateGlobalContent Boolean   @default(false)
  permissions           String?
  lastLoginAt           DateTime?
  failedLoginAttempts   Int       @default(0)
  lockedUntil           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([status, role])
  @@index([createdAt])
  @@index([email])
}

model ArchaeologicalDiscovery {
  id                  String    @id @default(cuid())
  name                String
  discoveryYear       Int
  description         String
  significance        String
  relatedExpedition   String?
  relatedExplorerName String?
  expeditionYear      Int?
  latitude            Float?
  longitude           Float?
  locationDescription String?
  waterwayId          String?
  sources             String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  waterway            Waterway? @relation(fields: [waterwayId], references: [id])
}

model Quiz {
  id          String         @id @default(cuid())
  title       String
  description String?
  gradeLevel  String?
  difficulty  String         @default("medium")
  category    String
  isPublished Boolean        @default(false)
  createdById String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  attempts    QuizAttempt[]
  questions   QuizQuestion[]

  @@index([category])
  @@index([gradeLevel])
  @@index([isPublished])
  @@index([createdById])
}

model QuizQuestion {
  id            String   @id @default(cuid())
  quizId        String
  questionText  String
  questionType  String   @default("multiple_choice")
  options       String
  correctAnswer String
  explanation   String?
  sourceType    String?
  sourceId      String?
  orderIndex    Int      @default(0)
  points        Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model QuizAttempt {
  id              String    @id @default(cuid())
  quizId          String
  studentName     String?
  studentGrade    String?
  schoolName      String?
  score           Int
  totalQuestions  Int
  totalPoints     Int
  maxPoints       Int
  percentageScore Float
  answers         String
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  quiz            Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model LessonPlan {
  id                    String            @id @default(cuid())
  title                 String
  description           String
  gradeLevel            String
  topic                 String
  curriculumConnections String?
  objectives            String
  estimatedMinutes      Int               @default(60)
  materials             String?
  introduction          String?
  mainContent           String
  activities            String?
  discussionQuestions   String?
  assessment            String?
  extensions            String?
  relatedQuizIds        String?
  relatedWaterwayIds    String?
  relatedLocationIds    String?
  relatedExplorerIds    String?
  isPublished           Boolean           @default(false)
  isCore                Boolean           @default(false)
  visibility            String            @default("private")
  createdById           String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  assignments           ClassAssignment[]

  // General User Deep Dive Content
  narrativeContent      String?           // Rich narrative for general users (answers to objectives/questions woven in)
  heroImageUrl          String?           // Main image for the topic
  images                String?           // JSON array of image objects [{url, caption, credit}]
  keyFigures            String?           // JSON array of historical figures relevant to topic
  timeline              String?           // JSON array of key dates/events
  readingTimeMinutes    Int?              // Estimated reading time for general users

  // Enhanced Teacher Content
  teacherObjectives     String?           // Additional learning objectives for teachers
  teacherActivities     String?           // Additional activities for teachers
  teacherQuestions      String?           // Additional discussion questions for teachers
  teacherNotes          String?           // Notes and tips for educators

  @@index([gradeLevel])
  @@index([isPublished])
  @@index([visibility])
  @@index([isCore])
  @@index([createdById])
  @@index([isPublished, visibility])
}

model TimelineEvent {
  id            String   @id @default(cuid())
  title         String
  description   String
  year          Int
  month         Int?
  day           Int?
  endYear       Int?
  isApproximate Boolean  @default(false)
  theme         String
  imageUrl      String?
  iconType      String?
  explorerId    String?
  waterwayId    String?
  locationId    String?
  importance    String   @default("normal")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model VirtualFieldTrip {
  id               String          @id @default(cuid())
  title            String
  description      String
  gradeLevel       String
  estimatedMinutes Int             @default(30)
  theme            String
  coverImageUrl    String?
  isPublished      Boolean         @default(false)
  isCore           Boolean         @default(false)
  visibility       String          @default("private")
  createdById      String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  stops            FieldTripStop[]

  @@index([gradeLevel])
  @@index([isPublished])
  @@index([visibility])
  @@index([isCore])
  @@index([createdById])
}

model FieldTripStop {
  id            String           @id @default(cuid())
  tripId        String
  orderIndex    Int
  title         String
  description   String
  locationId    String?
  waterwayId    String?
  latitude      Float
  longitude     Float
  imageUrl      String?
  audioUrl      String?
  funFact       String?
  thinkQuestion String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  trip          VirtualFieldTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model PrimarySourceDocument {
  id                  String   @id @default(cuid())
  title               String
  documentType        String
  author              String?
  originalDate        String?
  originalYear        Int?
  originalText        String?
  transcription       String?
  imageUrl            String?
  annotations         String?
  historicalContext   String?
  vocabulary          String?
  discussionQuestions String?
  explorerId          String?
  waterwayId          String?
  locationId          String?
  gradeLevel          String?
  isPublished         Boolean  @default(false)
  isCore              Boolean  @default(false)
  visibility          String   @default("private")
  createdById         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([gradeLevel])
  @@index([isPublished])
  @@index([visibility])
  @@index([isCore])
  @@index([createdById])
  @@index([documentType])
}

model ComparisonTemplate {
  id              String   @id @default(cuid())
  title           String
  description     String
  comparisonType  String
  items           String
  criteria        String
  analysisPrompts String?
  gradeLevel      String
  isPublished     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model StudentJournal {
  id                String          @id @default(cuid())
  studentIdentifier String
  studentName       String?
  schoolName        String?
  gradeLevel        String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  entries           JournalEntry[]
  savedLocations    SavedLocation[]
}

model JournalEntry {
  id           String         @id @default(cuid())
  journalId    String
  title        String?
  content      String
  waterwayId   String?
  locationId   String?
  explorerId   String?
  quizId       String?
  lessonPlanId String?
  fieldTripId  String?
  tags         String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  journal      StudentJournal @relation(fields: [journalId], references: [id], onDelete: Cascade)
}

model SavedLocation {
  id         String         @id @default(cuid())
  journalId  String
  waterwayId String?
  locationId String?
  explorerId String?
  notes      String?
  createdAt  DateTime       @default(now())
  journal    StudentJournal @relation(fields: [journalId], references: [id], onDelete: Cascade)
}

model Teacher {
  id                  String    @id @default(cuid())
  email               String    @unique
  name                String
  passwordHash        String
  schoolName          String?
  schoolDistrict      String?
  province            String?
  status              String    @default("pending")
  approvedBy          String?
  approvedAt          DateTime?
  rejectionReason     String?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  classes             Class[]

  @@index([status])
}

model Class {
  id          String            @id @default(cuid())
  name        String
  gradeLevel  String
  schoolYear  String?
  joinCode    String            @unique
  teacherId   String
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  teacher     Teacher           @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  assignments ClassAssignment[]
  students    ClassStudent[]
}

model ClassStudent {
  id          String            @id @default(cuid())
  classId     String
  displayName String
  studentCode String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  class       Class             @relation(fields: [classId], references: [id], onDelete: Cascade)
  progress    StudentProgress[]

  @@unique([classId, displayName])
}

model ClassAssignment {
  id             String            @id @default(cuid())
  classId        String
  assignmentType String
  quizId         String?
  lessonPlanId   String?
  fieldTripId    String?
  title          String
  instructions   String?
  dueDate        DateTime?
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  lessonPlan     LessonPlan?       @relation(fields: [lessonPlanId], references: [id])
  class          Class             @relation(fields: [classId], references: [id], onDelete: Cascade)
  progress       StudentProgress[]
}

model StudentProgress {
  id           String          @id @default(cuid())
  studentId    String
  assignmentId String
  status       String          @default("not_started")
  score        Int?
  maxScore     Int?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  assignment   ClassAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      ClassStudent    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, assignmentId])
}

model PrintableResource {
  id              String   @id @default(cuid())
  title           String
  description     String
  resourceType    String
  gradeLevel      String
  topic           String
  fileUrl         String?
  previewImageUrl String?
  content         String?
  teacherNotes    String?
  answerKey       String?
  isPublished     Boolean  @default(false)
  isCore          Boolean  @default(false)
  visibility      String   @default("private")
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([gradeLevel])
  @@index([isPublished])
  @@index([visibility])
  @@index([isCore])
  @@index([createdById])
  @@index([resourceType])
}

model PronunciationGuide {
  id                 String   @id @default(cuid())
  term               String
  termType           String
  language           String?
  phonetic           String
  audioUrl           String?
  meaning            String?
  notes              String?
  waterwayId         String?
  locationId         String?
  indigenousNationId String?
  explorerId         String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([term, termType])
}

model IndigenousWord {
  id                String         @id @default(cuid())
  word              String
  translation       String
  language          String
  phonetic          String?
  audioUrl          String?
  meaning           String?
  culturalContext   String?
  category          String?
  relatedWaterwayId String?
  relatedLocationId String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  wordOfDays        WordOfTheDay[]

  @@index([language])
  @@index([category])
}

model WordOfTheDay {
  id        String         @id @default(cuid())
  date      DateTime       @unique
  wordId    String
  createdAt DateTime       @default(now())
  word      IndigenousWord @relation(fields: [wordId], references: [id], onDelete: Cascade)
}

model VocabularyQuiz {
  id          String   @id @default(cuid())
  title       String
  language    String
  difficulty  String   @default("beginner")
  description String?
  questions   String
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([language])
  @@index([difficulty])
}

model IndigenousStory {
  id                String   @id @default(cuid())
  title             String
  nation            String
  language          String?
  content           String
  audioUrl          String?
  theme             String?
  gradeLevel        String?
  summary           String?
  relatedWaterwayId String?
  isPublished       Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([nation])
  @@index([theme])
}

model Achievement {
  id               String            @id @default(cuid())
  name             String            @unique
  description      String
  iconName         String
  category         String
  pointsRequired   Int               @default(0)
  criteria         String
  sortOrder        Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  earnedAt      DateTime    @default(now())
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
}

model UserProgress {
  id                    String    @id @default(cuid())
  userId                String    @unique
  totalPoints           Int       @default(0)
  explorerRank          String    @default("Apprentice Voyageur")
  waterwaysExplored     Int       @default(0)
  locationsVisited      Int       @default(0)
  quizzesTaken          Int       @default(0)
  quizPointsEarned      Int       @default(0)
  fieldTripsCompleted   Int       @default(0)
  journalEntriesWritten Int       @default(0)
  pronunciationsLearned Int       @default(0)
  documentsRead         Int       @default(0)
  dailyStreak           Int       @default(0)
  longestStreak         Int       @default(0)
  lastActiveDate        DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model DailyChallenge {
  id            String                  @id @default(cuid())
  date          DateTime                @unique
  question      String
  options       String
  correctAnswer String
  explanation   String
  pointsReward  Int                     @default(10)
  category      String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  attempts      DailyChallengeAttempt[]
}

model DailyChallengeAttempt {
  id          String         @id @default(cuid())
  userId      String
  challengeId String
  answer      String
  isCorrect   Boolean
  completedAt DateTime       @default(now())
  challenge   DailyChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@index([userId])
}

model VoyageurJourney {
  id               String                @id @default(cuid())
  title            String
  description      String
  gradeLevel       String
  difficulty       String                @default("medium")
  estimatedMinutes Int                   @default(20)
  coverImageUrl    String?
  startingLocation String
  endingLocation   String
  historicalYear   Int?
  isPublished      Boolean               @default(true)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  nodes            JourneyNode[]
  userJourneys     UserJourneyProgress[]
}

model JourneyNode {
  id                String          @id @default(cuid())
  journeyId         String
  nodeType          String
  orderIndex        Int
  title             String?
  narrative         String
  imageUrl          String?
  latitude          Float?
  longitude         Float?
  locationName      String?
  choices           String?
  challengeQuestion String?
  challengeAnswer   String?
  historicalFact    String?
  audioUrl          String?
  songLyrics        String?
  isEnding          Boolean         @default(false)
  endingType        String?
  createdAt         DateTime        @default(now())
  journey           VoyageurJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)
}

model UserJourneyProgress {
  id            String          @id @default(cuid())
  userId        String
  journeyId     String
  currentNodeId String?
  choicesMade   String
  score         Int             @default(0)
  status        String          @default("in_progress")
  startedAt     DateTime        @default(now())
  completedAt   DateTime?
  journey       VoyageurJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@unique([userId, journeyId])
  @@index([userId])
}

model HistoricalEvent {
  id            String   @id @default(cuid())
  title         String
  description   String
  latitude      Float
  longitude     Float
  locationName  String?
  year          Int
  month         Int?
  day           Int?
  isApproximate Boolean  @default(false)
  category      String
  explorerId    String?
  waterwayId    String?
  locationId    String?
  significance  String   @default("normal")
  imageUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([latitude, longitude])
  @@index([category])
}

model UserMapAnnotation {
  id              String     @id @default(cuid())
  userId          String
  title           String
  description     String?
  centerLatitude  Float?
  centerLongitude Float?
  zoomLevel       Float?
  isPublic        Boolean    @default(false)
  shareCode       String?    @unique
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  notes           MapNote[]
  pins            MapPin[]
  routes          MapRoute[]

  @@index([userId])
  @@index([shareCode])
}

model MapPin {
  id               String            @id @default(cuid())
  annotationId     String
  latitude         Float
  longitude        Float
  title            String
  description      String?
  color            String            @default("#FF6B6B")
  icon             String?
  linkedWaterwayId String?
  linkedLocationId String?
  linkedExplorerId String?
  createdAt        DateTime          @default(now())
  annotation       UserMapAnnotation @relation(fields: [annotationId], references: [id], onDelete: Cascade)
}

model MapRoute {
  id                  String            @id @default(cuid())
  annotationId        String
  title               String
  description         String?
  coordinates         String
  color               String            @default("#4ECDC4")
  strokeWidth         Int               @default(3)
  isDashed            Boolean           @default(false)
  compareToExplorerId String?
  createdAt           DateTime          @default(now())
  annotation          UserMapAnnotation @relation(fields: [annotationId], references: [id], onDelete: Cascade)
}

model MapNote {
  id              String            @id @default(cuid())
  annotationId    String
  latitude        Float
  longitude       Float
  content         String
  backgroundColor String            @default("#FFF3B0")
  createdAt       DateTime          @default(now())
  annotation      UserMapAnnotation @relation(fields: [annotationId], references: [id], onDelete: Cascade)
}

// Tracks the result of each URL checked by the nightly image health job.
// Used by GET /api/admin/image-health to surface broken links.
model ImageHealthLog {
  id          String   @id @default(cuid())
  checkedAt   DateTime @default(now())
  model       String   // e.g. "Waterway", "Explorer", "UserContribution"
  recordId    String
  field       String   // e.g. "imageUrl", "galleryImages[0]"
  url         String
  status      String   // "healthy" | "broken" | "rate_limited" | "unreachable" | "repaired"
  resolvedUrl String?  // populated when status == "repaired"

  @@index([checkedAt])
  @@index([status])
  @@index([model, recordId])
}

model NotableFigure {
  id                  String   @id @default(cuid())
  name                String
  alternateNames      String?
  birthYear           Int?
  deathYear           Int?
  nation              String?
  birthPlace          String?
  figureType          String
  role                String
  biography           String
